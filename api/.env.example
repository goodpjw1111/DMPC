# Copy to api/.env and fill in. NEVER commit the real .env.
# For the free 24/7 deploy (docs/DEPLOY.md §10) set the PROD values shown in comments.
APP_ENV=dev                              # PROD: prod
API_BASE_URL=http://localhost:8000       # PROD: https://YOUR.duckdns.org
WEB_ORIGIN=http://localhost:3000         # PROD: https://YOUR.duckdns.org

ALLOWED_EMAIL_DOMAIN=dimigo.hs.kr
# Comma-separated EXACT emails allowed to log in despite NOT being @ the domain above
# (operator exceptions; still require a Google-verified email).
ALLOW_EMAILS=goodpjw1111@gmail.com

# Comma-separated emails auto-granted 'admin' on login (idempotent; never demotes).
ADMIN_EMAILS=goodpjw2008@dimigo.hs.kr,goodpjw1111@gmail.com

# Google Cloud Console -> Credentials -> OAuth 2.0 Client ID (Web application).
# Authorized redirect URI must EXACTLY equal GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback   # PROD: https://YOUR.duckdns.org/auth/callback

# Server secret for deriving HIDDEN evaluation-round seeds (separate from SECRET_KEY).
# Used by the scheduler/grader. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
EVAL_SEED_SECRET=

# 32+ random bytes. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=
# Separate pepper for IP hashing (optional; falls back to SECRET_KEY).
IP_HASH_SECRET=
SESSION_TTL_HOURS=12
# Set true in production (https) — enables Secure cookies + __Host-/__Secure- + HSTS.
COOKIE_SECURE=false                      # PROD: true
# lax = single-origin (recommended, via reverse proxy). none = separate API origin
# (REQUIRES COOKIE_SECURE=true). See docs/DEPLOY.md.
COOKIE_SAMESITE=lax
# Trusted client-IP header for YOUR proxy (e.g. cf-connecting-ip). Empty = socket
# peer. Raw X-Forwarded-For is never trusted.
TRUSTED_IP_HEADER=

DATABASE_URL=postgresql://dmpc:dmpc@localhost:5432/dmpc

# Start CSP in report-only; flip to false to enforce once clean (prod requires false).
CSP_REPORT_ONLY=true                     # PROD: false

# NOTE: when APP_ENV=prod the API REFUSES TO BOOT if SECRET_KEY is default/short,
# COOKIE_SECURE is false, OAuth creds are empty, CSP is report-only, or origins
# still point at localhost. (api/app/_prodcheck.py)
