# Copy to web/.env.local

# SINGLE-ORIGIN (recommended): leave NEXT_PUBLIC_API_BASE empty and set
# API_PROXY_TARGET so Next proxies /api and /auth to the API on the same origin.
API_PROXY_TARGET=http://localhost:8000
NEXT_PUBLIC_API_BASE=

# SEPARATE API ORIGIN instead: unset API_PROXY_TARGET and set the API URL here
# (then the API must use COOKIE_SAMESITE=none + COOKIE_SECURE=true).
# NEXT_PUBLIC_API_BASE=https://api.example.com
